{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "obsidianlabs-io/obsidian-admin-laravel",
    "type": "project",
    "description": "Strictly-typed Laravel 12 admin backend with domain-driven boundaries, multi-tenancy, audit logs, OpenAPI generation, and official Octane integration.",
    "keywords": [
        "laravel",
        "laravel12",
        "php",
        "php84",
        "api",
        "backend",
        "admin",
        "ddd",
        "clean-architecture",
        "multi-tenancy",
        "saas",
        "rbac",
        "audit-logs",
        "openapi",
        "scramble",
        "sanctum",
        "octane",
        "roadrunner",
        "reverb",
        "redis",
        "horizon",
        "phpstan",
        "pest",
        "deptrac",
        "postgresql",
        "mysql"
    ],
    "homepage": "https://github.com/obsidianlabs-io/obsidian-admin-laravel",
    "authors": [
        {
            "name": "Obsidian Labs",
            "email": "obsidianlabs.tech@gmail.com",
            "homepage": "https://github.com/obsidianlabs-io",
            "role": "Maintainer"
        }
    ],
    "license": "MIT",
    "support": {
        "docs": "https://github.com/obsidianlabs-io/obsidian-admin-laravel#readme",
        "issues": "https://github.com/obsidianlabs-io/obsidian-admin-laravel/issues",
        "source": "https://github.com/obsidianlabs-io/obsidian-admin-laravel",
        "email": "obsidianlabs.tech@gmail.com"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/obsidianlabs-io"
        }
    ],
    "require": {
        "php": "^8.4",
        "dedoc/scramble": "^0.13.14",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.44",
        "laravel/octane": "^2.14",
        "laravel/pennant": "^1.19",
        "laravel/pulse": "^1.5",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.3",
        "spiral/roadrunner-cli": "^2.6.0",
        "spiral/roadrunner-http": "^3.3.0"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.6",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8.5",
        "pestphp/pest-plugin-laravel": "^3.2",
        "phpstan/phpstan": "^2.1.32",
        "phpunit/phpunit": "11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force"
        ],
        "dev": [
            "@php artisan serve"
        ],
        "octane:install": [
            "@php artisan octane:install --server=roadrunner"
        ],
        "octane:start": [
            "@php artisan octane:start --server=roadrunner"
        ],
        "octane:reload": [
            "@php artisan octane:reload --server=roadrunner"
        ],
        "octane:stop": [
            "@php artisan octane:stop --server=roadrunner"
        ],
        "analyse": [
            "@php artisan config:clear --ansi",
            "vendor/bin/phpstan analyse --memory-limit=1G"
        ],
        "quality:architecture": [
            "vendor/bin/pest tests/Architecture --colors=always",
            "vendor/bin/deptrac --config-file=deptrac.yaml --no-interaction"
        ],
        "contract:check": [
            "@php artisan config:clear --ansi",
            "@php artisan api:contract-snapshot"
        ],
        "openapi:lint": [
            "@php artisan openapi:lint"
        ],
        "security:check": [
            "@php artisan security:baseline"
        ],
        "docs:path-safety": [
            "@php scripts/check-public-path-safety.php"
        ],
        "release:pairing": [
            "@php scripts/check-release-pairing.php"
        ],
        "quality:check": [
            "@php artisan config:clear --ansi",
            "vendor/bin/pint --test",
            "vendor/bin/phpstan analyse --memory-limit=1G",
            "vendor/bin/pest tests/Architecture --colors=always",
            "vendor/bin/deptrac --config-file=deptrac.yaml --no-interaction",
            "@php scripts/check-public-path-safety.php",
            "@php artisan openapi:lint",
            "@php artisan api:contract-snapshot",
            "@php artisan security:baseline",
            "@php artisan http:proxy-trust-check --strict"
        ],
        "feature:rollout": [
            "@php artisan feature:rollout"
        ],
        "profile:apply": [
            "@php artisan project:profile:apply"
        ],
        "contract:write": [
            "@php artisan api:contract-snapshot --write"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:mysql": [
            "@php artisan config:clear --ansi",
            "vendor/bin/pest --configuration=phpunit.mysql.xml"
        ],
        "test:pgsql": [
            "@php artisan config:clear --ansi",
            "vendor/bin/pest --configuration=phpunit.pgsql.xml"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
